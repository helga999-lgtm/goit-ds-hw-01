# 1. Використовуємо офіційний легковаговий образ Python (відповідно до версії 3.14)
FROM python:3.14-slim

# 2. Встановлюємо робочу директорію всередині контейнера
WORKDIR /app

# 3. Копіюємо файли залежностей, щоб Docker міг закешувати їх інсталяцію
COPY pyproject.toml /app/

# 4. Встановлюємо Poetry всередині контейнера для менеджменту залежностей
RUN pip install --no-cache-dir poetry

# 5. Конфігуруємо Poetry так, щоб він не створював додаткове віртуальне середовище всередині контейнера
RUN poetry config virtualenvs.create false

# 6. Встановлюємо залежності, прописані в pyproject.toml (без середовища розробки)
RUN poetry install --no-root --no-interaction --no-ansi

# 7. Копіюємо решту файлів проекту (код, адресну книгу тощо) в контейнер
COPY . /app

# 8. Визначаємо головну команду для запуску вашого застосунку.
CMD ["python", "hw-08.py"]